@model List<Slider>
@{
    int count = 0;
}
<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Slider Table</h4>
                <p class="card-description">
                    <a asp-action="create" class="btn btn-outline-success btn-fw">Create</a>
                </p>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Image
                                </th>
                                <th>
                                    Title
                                </th>
                                <th>
                                    Subtitle
                                </th>
                                <th>
                                    Order
                                </th>
                                <th>
                                    Settings
                                </th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (Slider slider in Model)
                            {
                                <tr>
                                    <td>
                                        @(++count)
                                    </td>
                                    <td>
                                        <img src="~/assets/images/website-images/@slider.Image" />
                                    </td>
                                    <td>
                                        @slider.Title
                                    </td>
                                    <td>
                                        @slider.SubTitle
                                    </td>
                                    <td>
                                        @slider.Order
                                    </td>

                                    <td>
                                        <a asp-action="update" asp-route-id="@slider.Id" class="btn btn-outline-warning btn-fw">Edit</a>
                                        <a asp-action="delete" asp-route-id="@slider.Id" class="btn btn-outline-danger btn-fw">Delete</a>
                                        <a asp-action="details" asp-route-id="@slider.Id" class="btn btn-outline-info btn-fw">Detail</a>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>