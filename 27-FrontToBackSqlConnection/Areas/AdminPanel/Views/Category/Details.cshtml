@model Category
<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Category Detail</h4>
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" value="@Model.Name" readonly />
                </div>
                <h5 class="mt-4">Products (@(Model.Products?.Count ?? 0))</h5>
                @if (Model.Products == null || !Model.Products.Any())
                {
                    <p>No products in this category.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>SKU</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int i = 0;
                                }
                                @foreach (var product in Model.Products)
                                {
                                    <tr>
                                        <td>@(++i)</td>
                                        <td>@product.Name</td>
                                        <td>@string.Format("{0:C}", product.Price)</td>
                                        <td>@product.SKU</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                <a asp-action="index" class="btn btn-light mt-3">Back</a>
            </div>
        </div>
    </div>
</div>